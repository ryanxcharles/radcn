{
  "name": "radcn-candidate-remix",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm styles:build && node --watch --import remix/node-tsx server.ts",
    "start": "pnpm styles:build && node --import remix/node-tsx server.ts",
    "styles:build": "tailwindcss --input app/styles/tailwind.css --output app/assets/tailwind.generated.css",
    "typecheck": "tsc"
  },
  "dependencies": {
    "radcn": "workspace:*",
    "remix": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/cli": "catalog:",
    "@types/node": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:"
  }
}
